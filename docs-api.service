[Unit]
Description=Docs API (FastAPI/uvicorn)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/docs-api
Environment=PYTHONUNBUFFERED=1
ExecStart=/root/docs-api/venv/bin/uvicorn main:app --host 0.0.0.0 --port 9000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
